{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:4000",
        "EXPO_PUBLIC_WS_URL": "ws://localhost:4001",
        "EXPO_PUBLIC_LIVEKIT_URL": "wss://your-livekit.livekit.cloud"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.staging.proxm.app",
        "EXPO_PUBLIC_WS_URL": "wss://ws.staging.proxm.app",
        "EXPO_PUBLIC_LIVEKIT_URL": "wss://your-livekit.livekit.cloud",
        "EXPO_PUBLIC_MAPBOX_TOKEN": "YOUR_MAPBOX_TOKEN"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.proxm.app",
        "EXPO_PUBLIC_WS_URL": "wss://ws.proxm.app",
        "EXPO_PUBLIC_LIVEKIT_URL": "wss://your-livekit.livekit.cloud",
        "EXPO_PUBLIC_MAPBOX_TOKEN": "YOUR_MAPBOX_TOKEN"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "YOUR_APPLE_ID",
        "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "YOUR_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "internal"
      }
    }
  }
}
