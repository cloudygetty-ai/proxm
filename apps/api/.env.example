# Server
PORT=4000
WS_PORT=4001
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://proxm:proxm@localhost:5432/proxm

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min

# LiveKit
LIVEKIT_HOST=https://your-livekit-host.livekit.cloud
LIVEKIT_API_KEY=your_key
LIVEKIT_API_SECRET=your_secret

# AWS S3 (photo storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=proxm-photos

# Twilio (OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://proxm.app
